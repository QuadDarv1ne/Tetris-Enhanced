# Python source files
*.py	text eol=lf

# Config and data files
*.json	text eol=lf
*.md	text eol=lf
*.txt	text eol=lf
*.cfg	text eol=lf
*.ini	text eol=lf
*.yml	text eol=lf
*.yaml	text eol=lf

# Shell and build scripts
*.sh	text eol=lf
*.bat	text eol=crlf
*.cmd	text eol=crlf

# Auto-detect for everything else
*	text=auto
